<Window x:Class="IHM.AjoutVoitureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Créateur de Véhicule" Height="650" Width="1000" 
        WindowStartupLocation="CenterScreen" Background="{StaticResource LightBackground}">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Background="White" CornerRadius="8" Padding="15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="5" Opacity="0.1"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="1. Marque" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="0,0,0,10"/>

                <TextBlock Text="Nouvelle marque :" Foreground="#777" Margin="0,5"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtMarque" Height="30" VerticalContentAlignment="Center"/>
                    <Button Grid.Column="1" Content="+" Width="40" Margin="5,0,0,0" Click="BtnAjoutMarque_Click" Background="{StaticResource SecondaryColor}" Foreground="White" FontWeight="Bold"/>
                </Grid>

                <Separator Margin="0,15"/>
                <TextBlock Text="Ou sélectionner :" Foreground="#777" Margin="0,0,0,5"/>
                <ComboBox x:Name="CboMarques" SelectionChanged="CboMarques_SelectionChanged" DisplayMemberPath="Nom" Height="35"/>
            </StackPanel>
        </Border>

        <Border x:Name="GrpModele" Grid.Row="1" Grid.Column="0" IsEnabled="False">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="CornerRadius" Value="8"/>
                    <Setter Property="Padding" Value="15"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="5" Opacity="0.1"/>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="True">
                            <Setter Property="Opacity" Value="1.0"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <StackPanel>
                <TextBlock Text="2. Modèle" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="0,0,0,10"/>

                <TextBlock Text="Nouveau modèle :" Foreground="#777" Margin="0,5"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtModele" Height="30" VerticalContentAlignment="Center"/>
                    <Button Grid.Column="1" Content="+" Width="40" Margin="5,0,0,0" Click="BtnAjoutModele_Click" Background="{StaticResource PrimaryColor}" Foreground="White" FontWeight="Bold"/>
                </Grid>

                <Separator Margin="0,15"/>
                <TextBlock Text="Ou sélectionner :" Foreground="#777" Margin="0,0,0,5"/>
                <ComboBox x:Name="CboModeles" SelectionChanged="CboModeles_SelectionChanged" DisplayMemberPath="Nom" Height="35"/>
            </StackPanel>
        </Border>

        <Border x:Name="GrpGeneration" Grid.Row="0" Grid.Column="2" IsEnabled="False">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="CornerRadius" Value="8"/>
                    <Setter Property="Padding" Value="15"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="5" Opacity="0.1"/>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="True">
                            <Setter Property="Opacity" Value="1.0"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <StackPanel>
                <TextBlock Text="3. Version / Année" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Nom (ex: IV)" Foreground="#777"/>
                        <TextBox x:Name="TxtGenNom" Height="30" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Année" Foreground="#777"/>
                        <TextBox x:Name="TxtGenAnnee" Height="30" VerticalContentAlignment="Center"/>
                    </StackPanel>
                </Grid>
                <Button Content="Ajouter Version" Click="BtnAjoutGen_Click" Background="{StaticResource PrimaryColor}" Foreground="White" FontWeight="Bold" Height="30" Margin="0,0,0,15"/>

                <TextBlock Text="Sélectionner :" Foreground="#777"/>
                <ComboBox x:Name="CboGenerations" SelectionChanged="CboGenerations_SelectionChanged" DisplayMemberPath="Nom" Height="35"/>
            </StackPanel>
        </Border>

        <Border x:Name="GrpMoteur" Grid.Row="1" Grid.Column="2" IsEnabled="False">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="CornerRadius" Value="8"/>
                    <Setter Property="Padding" Value="15"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="5" Opacity="0.1"/>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="True">
                            <Setter Property="Opacity" Value="1.0"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <StackPanel>
                <TextBlock Text="4. Motorisation" FontSize="16" FontWeight="Bold" Foreground="{StaticResource DangerColor}" Margin="0,0,0,10"/>

                <TextBlock Text="Moteur (ex: 1.5 dCi)" Foreground="#777"/>
                <TextBox x:Name="TxtMoteurNom" Height="30" Margin="0,0,0,10" VerticalContentAlignment="Center"/>

                <TextBlock Text="Carburant" Foreground="#777"/>
                <ComboBox x:Name="CboCarburant" Height="30" Margin="0,0,0,15">
                    <ComboBoxItem Content="Diesel"/>
                    <ComboBoxItem Content="Essence"/>
                    <ComboBoxItem Content="Hybride"/>
                    <ComboBoxItem Content="Électrique"/>
                </ComboBox>

                <Button Content="TERMINER &amp; SAUVEGARDER" Click="BtnAjoutMoteur_Click" Background="{StaticResource DangerColor}" Foreground="White" Height="40" FontWeight="Bold"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>