<Window x:Class="IHM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Garage Manager - Recherche" Height="600" Width="900"
        WindowStartupLocation="CenterScreen" 
        WindowState="Maximized"
        Background="{StaticResource LightBackground}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="👤 GÉRER CLIENT" Click="BtnGestionClient_Click" Background="#6c757d" Foreground="White" Width="140"/>
                    <TextBlock x:Name="TxtClientSelectionne" Text="Aucun client sélectionné" VerticalAlignment="Center" Margin="15,0,0,0" FontStyle="Italic" Foreground="#555" FontSize="14"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Plaque :" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0" Foreground="#333"/>
                    <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="4">
                        <TextBox x:Name="TxtPlaque" Width="120" Height="30" CharacterCasing="Upper" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="16" FontWeight="Bold" BorderThickness="0" Background="Transparent"/>
                    </Border>
                    <Button Content="🔍" Click="BtnChercherPlaque_Click" Width="40" Height="30" Background="{StaticResource PrimaryColor}" Foreground="White" FontWeight="Bold" Margin="5,0,0,0"/>
                    <Button x:Name="BtnSavePlaque" Content="💾" Click="BtnMemoriserPlaque_Click" Width="40" Height="30" Margin="5,0,0,0" Background="{StaticResource SecondaryColor}" Foreground="White" ToolTip="Mémoriser le véhicule"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="30" HorizontalAlignment="Center" VerticalAlignment="Top" Width="600">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.1"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Identifier le véhicule" FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="0,0,0,25" HorizontalAlignment="Center"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Marque" VerticalAlignment="Center" FontWeight="SemiBold" Grid.Row="0"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding ListeMarques}" SelectedItem="{Binding MarqueSelected}" DisplayMemberPath="Nom" Height="35"/>

                    <TextBlock Text="Modèle" VerticalAlignment="Center" FontWeight="SemiBold" Grid.Row="1"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding ListeModeles}" SelectedItem="{Binding ModeleSelected}" DisplayMemberPath="Nom" Height="35"/>

                    <TextBlock Text="Version" VerticalAlignment="Center" FontWeight="SemiBold" Grid.Row="2"/>
                    <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding ListeGenerations}" SelectedItem="{Binding GenerationSelected}" DisplayMemberPath="Nom" Height="35"/>

                    <TextBlock Text="Moteur" VerticalAlignment="Center" FontWeight="SemiBold" Grid.Row="3"/>
                    <ComboBox Grid.Row="3" Grid.Column="1" ItemsSource="{Binding ListeMoteurs}" SelectedItem="{Binding MoteurSelected}" DisplayMemberPath="Nom" Height="35"/>
                </Grid>

                <Button Content="VOIR LES PIÈCES DISPONIBLES ➔" Height="50" Background="{StaticResource PrimaryColor}" Foreground="White" Click="BtnVoirPieces_Click" Margin="0,30,0,0" FontSize="16"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>