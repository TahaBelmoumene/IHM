<Window x:Class="IHM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Garage Manager - Recherche" Height="500" Width="800"
        WindowStartupLocation="CenterScreen" 
        WindowState="Maximized">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="👤 CLIENT" Click="BtnGestionClient_Click" Width="100" Height="30" Background="#6c757d" Foreground="White"/>
            <TextBlock x:Name="TxtClientSelectionne" Text="Aucun client sélectionné" VerticalAlignment="Center" Margin="10,0,0,0" FontStyle="Italic"/>
        </StackPanel>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
            <TextBlock Text="Plaque :" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,5,0" Foreground="#555"/>
            <TextBox x:Name="TxtPlaque" Width="100" Height="25" CharacterCasing="Upper" VerticalContentAlignment="Center" ToolTip="AA-123-BB"/>
            <Button Content="🔍" Click="BtnChercherPlaque_Click" Width="30" Height="25" Background="#FF9800" Foreground="White" FontWeight="Bold" Margin="5,0,0,0"/>

            <Button x:Name="BtnSavePlaque" Content="💾" Click="BtnMemoriserPlaque_Click" Width="25" Height="25" Margin="5,0,0,0" 
                Background="Transparent" BorderBrush="Gray" ToolTip="Mémoriser le véhicule sélectionné pour cette plaque"/>
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <TextBlock Text="Identifier le véhicule" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

            <TextBlock Text="Marque :"/>
            <ComboBox ItemsSource="{Binding ListeMarques}" SelectedItem="{Binding MarqueSelected}" DisplayMemberPath="Nom" Margin="0,5,0,15"/>

            <TextBlock Text="Modèle :"/>
            <ComboBox ItemsSource="{Binding ListeModeles}" SelectedItem="{Binding ModeleSelected}" DisplayMemberPath="Nom" Margin="0,5,0,15"/>

            <TextBlock Text="Année / Version :"/>
            <ComboBox ItemsSource="{Binding ListeGenerations}" SelectedItem="{Binding GenerationSelected}" DisplayMemberPath="Nom" Margin="0,5,0,15"/>

            <TextBlock Text="Motorisation :"/>
            <ComboBox ItemsSource="{Binding ListeMoteurs}" SelectedItem="{Binding MoteurSelected}" DisplayMemberPath="Nom" Margin="0,5,0,30"/>

            <Button Content="VOIR LES PIÈCES DISPONIBLES" Height="40" Background="#007ACC" Foreground="White" Click="BtnVoirPieces_Click"/>
        </StackPanel>
    </Grid>
</Window>