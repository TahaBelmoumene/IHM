<Window x:Class="IHM.ChoixCategorieWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Choisir une catégorie" Height="500" Width="600"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock x:Name="TxtTitreVoiture" Text="Pièces pour : [Voiture Choisie]" 
                       FontSize="20" FontWeight="Bold" Margin="0,0,0,10" Foreground="#333"/>

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnRetour" Content="⬅ Retour" Click="BtnRetour_Click" 
                        Width="80" Height="30" Visibility="Collapsed" 
                        Background="#6c757d" Foreground="White" FontWeight="Bold" Margin="0,0,15,0"/>

                <TextBlock x:Name="TxtAriane" Grid.Column="1" Text="Rayons Principaux" 
                           FontSize="16" VerticalAlignment="Center" Foreground="#007ACC" TextTrimming="CharacterEllipsis"/>
            </Grid>

            <TextBlock Text="Double-cliquez pour ouvrir un dossier :" Margin="0,0,0,5" FontStyle="Italic" Foreground="Gray"/>

            <ListBox x:Name="LstCategories" Height="330" MouseDoubleClick="LstCategories_MouseDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Padding="10" Margin="5" Width="500">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="📁" FontSize="20" Margin="0,0,15,0" VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="1" Text="{Binding Nom}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="2" Text="➤" FontSize="14" Foreground="#CCC" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
    </Grid>
</Window>