<Window x:Class="IHM.ChoixCategorieWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Choisir une catégorie" Height="500" Width="600"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock x:Name="TxtTitreVoiture" Text="Pièces pour : [Voiture Choisie]" 
                       FontSize="20" FontWeight="Bold" Margin="0,0,0,10" Foreground="#333"/>

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnRetour" Content="⬅ Retour" Click="BtnRetour_Click" 
                        Width="80" Height="30" Visibility="Collapsed" 
                        Background="#6c757d" Foreground="White" FontWeight="Bold" Margin="0,0,15,0"/>

                <TextBlock x:Name="TxtAriane" Grid.Column="1" Text="Rayons Principaux" 
                           FontSize="16" VerticalAlignment="Center" Foreground="#007ACC" TextTrimming="CharacterEllipsis"/>
            </Grid>

            <TextBlock Text="Double-cliquez pour ouvrir un dossier :" Margin="0,0,0,5" FontStyle="Italic" Foreground="Gray"/>
            <ListBox x:Name="LstCategories" MouseDoubleClick="LstCategories_MouseDoubleClick"
         Background="Transparent" BorderThickness="0" 
         ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" Width="140" Height="120" CornerRadius="8" Margin="10" Padding="10">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
                            </Border.Effect>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="📁" FontSize="40" HorizontalAlignment="Center" Foreground="#FFC107"/>
                                <TextBlock Text="{Binding Nom}" 
                               FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" TextAlignment="Center" 
                               Margin="0,10,0,0" Foreground="#333"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
    </Grid>
</Window>