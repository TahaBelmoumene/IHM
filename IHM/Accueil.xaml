<Window x:Class="IHM.Accueil"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Garage Manager - Dashboard" Height="600" Width="900"
        WindowStartupLocation="CenterScreen" Background="{StaticResource LightBackground}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource PrimaryColor}" Padding="20">
            <StackPanel>
                <TextBlock Text="GARAGE MANAGER" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Gestion d'atelier simplifiée" FontSize="14" Foreground="#DDFFFFFF" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="40" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="150"/>
                <RowDefinition Height="150"/>
            </Grid.RowDefinitions>

            <Button Grid.Row="0" Grid.Column="0" Click="BtnTrouver_Click" Background="White" Margin="10">
                <StackPanel>
                    <TextBlock Text="🔍" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="TROUVER UNE PIÈCE" Foreground="#333" FontWeight="Bold"/>
                </StackPanel>
            </Button>

            <Button Grid.Row="0" Grid.Column="1" Click="BtnAjouterPiece_Click" Background="White" Margin="10">
                <StackPanel>
                    <TextBlock Text="➕" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="AJOUTER STOCK" Foreground="#333" FontWeight="Bold"/>
                </StackPanel>
            </Button>

            <Button Grid.Row="0" Grid.Column="2" Click="BtnModifierPiece_Click" Background="White" Margin="10">
                <StackPanel>
                    <TextBlock Text="✏️" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="MODIFIER STOCK" Foreground="#333" FontWeight="Bold"/>
                </StackPanel>
            </Button>

            <Button Grid.Row="1" Grid.Column="0" Click="BtnAjouterVoiture_Click" Background="White" Margin="10">
                <StackPanel>
                    <TextBlock Text="🚗" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="NOUVEAU VÉHICULE" Foreground="#333" FontWeight="Bold"/>
                </StackPanel>
            </Button>

            <Button Grid.Row="1" Grid.Column="1" Click="BtnGererRayons_Click" Background="White" Margin="10">
                <StackPanel>
                    <TextBlock Text="🗂️" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="ARCHITECTE RAYONS" Foreground="#333" FontWeight="Bold"/>
                </StackPanel>
            </Button>

            <Button Grid.Row="1" Grid.Column="2" Background="#EEE" Margin="10" IsEnabled="False">
                <StackPanel>
                    <TextBlock Text="📊" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10" Opacity="0.5"/>
                    <TextBlock Text="STATISTIQUES" Foreground="#999" FontWeight="Bold"/>
                </StackPanel>
            </Button>

        </Grid>
    </Grid>
</Window>